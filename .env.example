# Magic MariaDB Sync - Environment Configuration
# Copy this file to .env and adjust values as needed

# Application environment: "dev" or "prod"
# APP_ENV=dev

# HTTP server bind address
# LISTEN_ADDR=127.0.0.1:8080

# Path to SQLite metadata database
# META_DB_PATH=./magic.db

# REQUIRED: Path to encryption key file
# ENCRYPTION_KEY_PATH=/path/to/keyfile

# Logging level: debug, info, warn, error
# LOG_LEVEL=info

# Enable Prometheus metrics endpoint
# METRICS_ENABLED=false

# Allow remote access (INsecure - not recommended for production)
# MAGIC_ALLOW_REMOTE=false